# =============================================================================
# .env de STAGING — servidor /home/deploy/apps/aerobi-api-staging/.env.staging
#
# NÃO é usado diretamente: o workflow `Release & Deploy` (job deploy-staging)
# GERA este arquivo a partir dos secrets/variables do GitHub Environment
# 'staging' e faz scp para a VPS. Este exemplo serve só de referência/local.
#
# NÃO commitar com valores reais (.env.* está no .gitignore).
# =============================================================================

# App
NODE_ENV=staging
# PORT = porta interna do container (FIXA 3333). HOST_PORT = bind de host.
PORT=3333
# HOST_PORT vem da FONTE DA VERDADE do Ansible:
#   aerobi-ansible/inventory/prod/group_vars/all/ports.yml → app_ports.staging['aerobi-api']
HOST_PORT=3433
CORS_ORIGINS=https://staging.aerobi.com.br

# Docker image (usados pelo docker-compose.staging.yml) — MESMA imagem de prod
REGISTRY=ghcr.io
IMAGE_NAME=atzaero/aerobi-api
TAG=latest

# Banco de dados de STAGING — host `postgres` na rede warpgate (Ansible).
# Banco/usuário isolados de produção (provisionados por setup_app_databases.yml):
#   db=aerobi_staging  user=aerobi_staging_user  (senha no ansible-vault)
DATABASE_URL=postgresql://aerobi_staging_user:<PREENCHER_SENHA_VAULT_STAGING>@postgres:5432/aerobi_staging?schema=public

# Frontend de staging (emails de convite/reset)
FRONTEND_URL=https://staging.aerobi.com.br

# Auth API Aerobi (X-API-Key) — chave própria de staging
# AEROBI_API_KEY=<PREENCHER>
# AEROBI_REQUIRE_AUTH=true

# Demais integrações (Plugfield/AISWEB/AviaScan/JWT) — mesmos nomes da prod,
# valores de staging. Ver docs/DEPLOY_STAGING.md para a lista completa.
