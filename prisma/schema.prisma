generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RabSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum PrivateAerodromesSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model RabSyncState {
  id             String        @id @default(cuid())
  period         String        @unique
  sourceUrl      String        @map("source_url")
  lastModified   String?       @map("last_modified")
  contentLength  BigInt?       @map("content_length")
  contentHash    String?       @map("content_hash")
  parsedRowCount Int?          @map("parsed_row_count")
  syncedAt       DateTime?     @map("synced_at") @db.Timestamptz(3)
  status         RabSyncStatus @default(PENDING)
  errorMessage   String?       @map("error_message")

  @@map("rab_sync_state")
}

/// Linhas do CSV RAB ANAC; chave natural (period, marcas). Colunas espelham o header oficial.
model RabRow {
  id                     String  @id @default(cuid())
  period                 String
  marcas                 String
  proprietarios          String?
  operadores             String?
  nrCertMatricula        String? @map("nr_cert_matricula")
  nrSerie                String? @map("nr_serie")
  cdTipo                 String? @map("cd_tipo")
  dsModelo               String? @map("ds_modelo")
  nmFabricante           String? @map("nm_fabricante")
  cdCls                  String? @map("cd_cls")
  nrPmd                  String? @map("nr_pmd")
  cdTipoIcao             String? @map("cd_tipo_icao")
  nrTripulacaoMin        String? @map("nr_tripulacao_min")
  nrPassageirosMax       String? @map("nr_passageiros_max")
  nrAssentos             String? @map("nr_assentos")
  nrAnoFabricacao        String? @map("nr_ano_fabricacao")
  dtValidadeCva          String? @map("dt_validade_cva")
  dtValidadeCa           String? @map("dt_validade_ca")
  dtCanc                 String? @map("dt_canc")
  dsMotivoCanc           String? @map("ds_motivo_canc")
  cdInterdicao           String? @map("cd_interdicao")
  dsGravame              String? @map("ds_gravame")
  dtMatricula            String? @map("dt_matricula")
  tpMotor                String? @map("tp_motor")
  qtMotor                String? @map("qt_motor")
  tpPouso                String? @map("tp_pouso")
  tpCa                   String? @map("tp_ca")
  cdPropositoCave        String? @map("cd_proposito_cave")
  cfOperacional          String? @map("cf_operacional")
  dsCategoriaHomologacao String? @map("ds_categoria_homologacao")
  tpOperacao             String? @map("tp_operacao")

  @@unique([period, marcas])
  @@index([period])
  @@map("rab_row")
}

model PrivateAerodromesSyncState {
  id             String                      @id @default(cuid())
  datasetKey     String                      @unique @map("dataset_key")
  datasetVersion String?                     @map("dataset_version")
  sourceUrl      String                      @map("source_url")
  lastModified   String?                     @map("last_modified")
  contentLength  BigInt?                     @map("content_length")
  contentHash    String?                     @map("content_hash")
  parsedRowCount Int?                        @map("parsed_row_count")
  syncedAt       DateTime?                   @map("synced_at") @db.Timestamptz(3)
  status         PrivateAerodromesSyncStatus @default(PENDING)
  errorMessage   String?                     @map("error_message")

  @@map("private_aerodromes_sync_state")
}

enum PublicAerodromesSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model PublicAerodromesSyncState {
  id             String                     @id @default(cuid())
  datasetKey     String                     @unique @map("dataset_key")
  datasetVersion String?                    @map("dataset_version")
  sourceUrl      String                     @map("source_url")
  lastModified   String?                    @map("last_modified")
  contentLength  BigInt?                    @map("content_length")
  contentHash    String?                    @map("content_hash")
  parsedRowCount Int?                       @map("parsed_row_count")
  syncedAt       DateTime?                  @map("synced_at") @db.Timestamptz(3)
  status         PublicAerodromesSyncStatus @default(PENDING)
  errorMessage   String?                    @map("error_message")

  @@map("public_aerodromes_sync_state")
}

model PublicAerodrome {
  id               String  @id @default(cuid())
  codigoOaci       String? @map("codigo_oaci")
  ciad             String  @unique
  nome             String?
  municipio        String?
  uf               String?
  municipioServido String? @map("municipio_servido")
  ufServido        String? @map("uf_servido")
  latitude         String?
  longitude        String?
  altitude         String?
  operacaoDiurna   String? @map("operacao_diurna")
  operacaoNoturna  String? @map("operacao_noturna")
  situacao         String?
  validadeRegistro String? @map("validade_registro")
  portariaRegistro String? @map("portaria_registro")
  linkPortaria     String? @map("link_portaria")
  latGeoPoint      String? @map("lat_geo_point")
  lonGeoPoint      String? @map("lon_geo_point")

  @@index([codigoOaci])
  @@index([uf, municipio])
  @@map("public_aerodrome")
}

model PrivateAerodrome {
  id               String  @id @default(cuid())
  codigoOaci       String? @map("codigo_oaci")
  ciad             String  @unique
  nome             String?
  municipio        String?
  uf               String?
  longitude        String?
  latitude         String?
  altitude         String?
  operacaoDiurna   String? @map("operacao_diurna")
  operacaoNoturna  String? @map("operacao_noturna")
  designacao1      String? @map("designacao_1")
  comprimento1     String? @map("comprimento_1")
  largura1         String? @map("largura_1")
  resistencia1     String? @map("resistencia_1")
  superficie1      String? @map("superficie_1")
  designacao2      String? @map("designacao_2")
  comprimento2     String? @map("comprimento_2")
  largura2         String? @map("largura_2")
  resistencia2     String? @map("resistencia_2")
  superficie2      String? @map("superficie_2")
  portariaRegistro String? @map("portaria_registro")
  linkPortaria     String? @map("link_portaria")
  latGeoPoint      String? @map("lat_geo_point")
  lonGeoPoint      String? @map("lon_geo_point")

  @@index([codigoOaci])
  @@index([uf, municipio])
  @@map("private_aerodrome")
}

// =============================================================================
// Domínio operacional (ex-Firestore). Ver docs/PADRAO_DATAS_UTC.md,
// docs/OPERACIONAL_ANALISE_REDUNDANCIA.md e aerobi-web/docs/data-model/model.ts.
// Todas as entidades: auditoria completa +
// DateTime com @db.Timestamptz(3), exceto campos explicitamente @db.Date.
// Ordem nos modelos: campos de negócio → relações [] → campos *At / *By (incl. revisão/pouso/etc.) → @@index/@@map.
// PKs e FKs internas: UUID (`@default(uuid()) @db.Uuid`). Tabelas legadas RAB/ANAC
// acima permanecem com `cuid()` — não alterar.
// =============================================================================

/// Siglas das UFs do Brasil (alinhado a `BR_UFS` / tipo `Uf` no model.ts do web).
enum Uf {
  AC
  AL
  AM
  AP
  BA
  CE
  DF
  ES
  GO
  MA
  MG
  MS
  MT
  PA
  PB
  PE
  PI
  PR
  RJ
  RN
  RO
  RR
  RS
  SC
  SE
  SP
  TO
}

enum LandingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GeojsonStatus {
  READY
  ERROR
}

enum GeojsonKind {
  AERODROME_MAP
}

enum GeojsonMapFileType {
  KML
  KMZ
}

/// Tipos de documento de aeródromo (coleção `documents` no Firestore). Os 6
/// primeiros são "singleton" (o aeródromo desnormaliza 1 `*_url` por tipo,
/// refletindo o mais recente); `other_ordinance`/`extra` são sempre múltiplos.
/// Persistido em MAIÚSCULAS; exposto/aceito em lowercase no contrato (paridade
/// web) e usado como `docType` do storage via lowercase.
enum DocumentType {
  IMAGE
  KML
  PLAN_ORDINANCE
  REGISTRATION_ORDINANCE
  GRANT_TERM
  AERONAUTICAL_STUDY
  OTHER_ORDINANCE
  EXTRA
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

/// Grupo de aeródromos por UF (equivale a `states/{uf}/groups/{id}` no Firestore).
model Group {
  id                String   @id @default(uuid()) @db.Uuid
  uf                Uf
  name              String
  ownerId           String?  @map("owner_id")
  deletionRequested Boolean? @map("deletion_requested")
  /// Key (MinIO) da imagem ativa do grupo — desnormalizada para evitar N+1 na
  /// listagem. Guarda a key, nunca a URL (presigned é resolvida on-read).
  imageKey          String?  @map("image_key") @db.Text

  aerodromes Aerodrome[]
  users      User[]
  images     GroupImage[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([uf])
  @@map("groups")
}

/// Aeródromo gerenciado no produto (distinto de cadastro ANAC público/privado).
model Aerodrome {
  id      String @id @default(uuid()) @db.Uuid
  groupId String @map("group_id") @db.Uuid
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Restrict)

  icao        String
  ciad        String?
  designation String? @map("designation")
  length      String? @map("length")
  width       String? @map("width")
  resistance  String? @map("resistance")
  surface     String? @map("surface")
  altitude    String? @map("altitude")

  name                     String   @map("name")
  municipality             String?  @map("municipality")
  latitude                 String   @map("latitude")
  longitude                String   @map("longitude")
  latitudeFormatted        String?  @map("latitude_formatted")
  longitudeFormatted       String?  @map("longitude_formatted")
  operation                String?  @map("operation")
  emergencyPhone           String?  @map("emergency_phone")
  lit                      Boolean? @map("lit")
  fueling                  Boolean? @map("fueling")
  observation              String?  @map("observation") @db.Text
  construction             Boolean? @map("construction")
  isOpen                   Boolean  @map("is_open")
  isView                   Boolean  @map("is_view")
  weatherStationCode       String?  @map("weather_station_code")
  weatherStationDisplay    Boolean? @map("weather_station_display")
  fileType                 String?  @map("file_type")
  imgUrl                   String?  @map("img_url") @db.Text
  kmlUrl                   String?  @map("kml_url") @db.Text
  registrationOrdinanceUrl String?  @map("registration_ordinance_url") @db.Text
  planOrdinanceUrl         String?  @map("plan_ordinance_url") @db.Text
  grantTermUrl             String?  @map("grant_term_url") @db.Text
  aeronauticalStudyUrl     String?  @map("aeronautical_study_url") @db.Text
  weatherUrl               String?  @map("weather_url") @db.Text
  windUrl                  String?  @map("wind_url") @db.Text
  videoUrl                 String?  @map("video_url") @db.Text

  landingRequests LandingRequest[]
  technicalVisits TechnicalVisit[]
  /// No máximo um GeoJSON operacional por aeródromo (1:1).
  geojson         Geojson?
  feedbacks       Feedback[]
  pilotLandings   PilotLanding[]
  maintenances    Maintenance[]
  cameras         Camera[]
  documents       Document[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  /// Unicidade de (groupId, icao) apenas entre aeródromos ATIVOS, garantida por
  /// índice único parcial `WHERE deleted_at IS NULL` (migration
  /// 20260701012000_aerodrome_partial_unique_icao). O Prisma não modela índice
  /// parcial no schema — NÃO re-adicionar `@@unique([groupId, icao])` (voltaria a
  /// reservar o ICAO de registros soft-deletados e a impedir a recriação).
  @@index([groupId])
  @@index([icao, isView])
  @@map("aerodromes")
}

/// Solicitação de pouso (unifica awaitemails + answeredemails).
model LandingRequest {
  id          String    @id @default(uuid()) @db.Uuid
  aerodromeId String    @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Restrict)

  status      LandingRequestStatus @map("status")
  requestDate DateTime             @map("request_date") @db.Timestamptz(3)

  email                String? @map("email")
  pilotCode            String? @map("pilot_code")
  aircraftModel        String? @map("aircraft_model")
  aircraftRegistration String? @map("aircraft_registration")
  departureAerodrome   String? @map("departure_aerodrome")
  observation          String? @map("observation") @db.Text

  /// Dados do piloto/solicitante e da operação, espelhando o formulário público
  /// (Firestore legado). Nullable para compatibilidade com registros migrados que
  /// gravavam só o subconjunto mínimo. `pilotCpf` guarda os 11 dígitos crus
  /// (mascarado no response de leitura; omitido no export).
  pilotName                String?  @map("pilot_name")
  pilotCpf                 String?  @map("pilot_cpf")
  phoneContact             String?  @map("phone_contact")
  requesterName            String?  @map("requester_name")
  peopleOnBoard            Int?     @map("people_on_board")
  acceptedTerms            Boolean? @map("accepted_terms")
  confirmedTrue            Boolean? @map("confirmed_true")
  foreignRegistration      Boolean? @map("foreign_registration")
  nextDestinationAerodrome String?  @map("next_destination_aerodrome")

  /// ICAO do aeródromo de chegada (uppercase) e UF, desnormalizados do aeródromo
  /// no create — usados por filtros e pela conformidade (paridade com o web).
  icao String? @map("icao")
  uf   Uf?     @map("uf")

  /// Janela operacional prevista (subsume a #150). Gravada em UTC.
  departureAt        DateTime? @map("departure_at") @db.Timestamptz(3)
  landingAt          DateTime? @map("landing_at") @db.Timestamptz(3)
  exitAfterLandingAt DateTime? @map("exit_after_landing_at") @db.Timestamptz(3)

  /// Snapshot RAB da aeronave no momento da solicitação (só matrícula nacional
  /// encontrada no RAB). 1:1, morre junto com a solicitação num hard delete.
  aircraft LandingRequestAircraft?

  /// Momento em que o coordenador revisou e aprovou ou rejeitou (Firestore legado: `responseDate`).
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(3)
  /// Ator (users.id ou `public`/uid legado) de quem revisou (legado: `responseby.uid`).
  reviewedBy String?   @map("reviewed_by")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([aerodromeId, status])
  @@index([aerodromeId, requestDate])
  @@index([icao, status])
  @@index([aircraftRegistration])
  @@map("landing_requests")
}

/// Snapshot do registro RAB da aeronave no instante da solicitação de pouso —
/// espelha a coleção satélite `landing_request_aircraft` do web (mesmos campos do
/// `RabRow`). Vínculo 1:1 com `LandingRequest` (`onDelete: Cascade`); gravado só
/// quando a matrícula nacional é encontrada de forma exata no RAB.
model LandingRequestAircraft {
  id String @id @default(uuid()) @db.Uuid

  landingRequestId String         @unique @map("landing_request_id") @db.Uuid
  landingRequest   LandingRequest @relation(fields: [landingRequestId], references: [id], onDelete: Cascade)

  period String
  marcas String

  proprietarios          String?
  operadores             String?
  nrCertMatricula        String? @map("nr_cert_matricula")
  nrSerie                String? @map("nr_serie")
  cdTipo                 String? @map("cd_tipo")
  dsModelo               String? @map("ds_modelo")
  nmFabricante           String? @map("nm_fabricante")
  cdCls                  String? @map("cd_cls")
  nrPmd                  String? @map("nr_pmd")
  cdTipoIcao             String? @map("cd_tipo_icao")
  nrTripulacaoMin        String? @map("nr_tripulacao_min")
  nrPassageirosMax       String? @map("nr_passageiros_max")
  nrAssentos             String? @map("nr_assentos")
  nrAnoFabricacao        String? @map("nr_ano_fabricacao")
  dtValidadeCva          String? @map("dt_validade_cva")
  dtValidadeCa           String? @map("dt_validade_ca")
  dtCanc                 String? @map("dt_canc")
  dsMotivoCanc           String? @map("ds_motivo_canc")
  cdInterdicao           String? @map("cd_interdicao")
  dsGravame              String? @map("ds_gravame")
  dtMatricula            String? @map("dt_matricula")
  tpMotor                String? @map("tp_motor")
  qtMotor                String? @map("qt_motor")
  tpPouso                String? @map("tp_pouso")
  tpCa                   String? @map("tp_ca")
  cdPropositoCave        String? @map("cd_proposito_cave")
  cfOperacional          String? @map("cf_operacional")
  dsCategoriaHomologacao String? @map("ds_categoria_homologacao")
  tpOperacao             String? @map("tp_operacao")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("landing_request_aircraft")
}

/// Câmera (metadados) de um aeródromo. Fonte de verdade no Postgres — o proxy
/// `streams` v2 (#473) lê daqui; o CRUD interno (JWT) escreve. O cadastro no
/// Firestore (legado) é migrado por backfill.
model Camera {
  id          String    @id @default(uuid()) @db.Uuid
  aerodromeId String    @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Restrict)

  /// Desnormalizado de `Aerodrome.icao` — serve a listagem pública
  /// (`/aerodromes/:icao/cameras`) e o proxy `streams` sem join. Mantido em
  /// sincronia na escrita (derivado do aeródromo de destino).
  icao String

  name         String  @map("name")
  mediamtxNode String  @map("mediamtx_node")
  mediamtxPath String  @map("mediamtx_path")
  /// Toggle operacional (desligar sem remover). Distinto do soft-delete
  /// (`deletedAt`): uma câmera pode estar ativa mas desligada.
  enabled      Boolean @default(true) @map("enabled")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  /// Unicidade de stream `(icao, mediamtx_node, mediamtx_path)` apenas entre
  /// câmeras ATIVAS, garantida por índice único parcial `WHERE deleted_at IS
  /// NULL` na migration (o Prisma não modela índice parcial no schema — NÃO
  /// adicionar `@@unique`, voltaria a reservar o trio de registros
  /// soft-deletados). Complementado por validação na escrita (assertStreamUnique).
  @@index([aerodromeId])
  @@index([icao])
  @@map("cameras")
}

/// Tipo de operação de um movimento no aeródromo (no jargão de aviação,
/// "movimento" = pouso ou decolagem).
enum MovementType {
  LANDING
  TAKEOFF
}

/// Origem do registro do movimento: `AUTOMATIC` = ingerido pelo pipeline de
/// câmeras (aviascan-cv); `MANUAL` = inserido por um usuário via interface.
enum MovementSource {
  AUTOMATIC
  MANUAL
}

/// Status de conformidade de um movimento perante a regra de pedido de aterragem
/// aprovado. `PENDING` = aplicável mas ainda não avaliado (a avaliação é
/// assíncrona/best-effort); `CONFORMANT` = pouso com pedido aprovado
/// correspondente; `NON_CONFORMANT` = pouso sem pedido correspondente (gera
/// `OperationalEvent`); `NOT_APPLICABLE` = a regra não se aplica (decolagem ou
/// movimento sem ICAO de aeródromo). A regra cobre pousos de ambas as origens
/// (AUTOMATIC e MANUAL).
enum ConformityStatus {
  PENDING
  CONFORMANT
  NON_CONFORMANT
  NOT_APPLICABLE
}

/// Movimento de aeronave em um aeródromo — um pouso ou uma decolagem. Quando a
/// origem é `AUTOMATIC`, a matrícula é reconhecida por OCR a partir de uma
/// imagem de câmera (pipeline aviascan-cv → aerobi-api). Quando `MANUAL`, é
/// preenchido por um usuário. Cada registro guarda a matrícula, a imagem (key no
/// MinIO), o tipo de operação, a origem e o status de validação humana; os dados
/// cadastrais da aeronave no instante do movimento ficam congelados em
/// {@link MovementAircraftSnapshot}.
model Movement {
  id String @id @default(uuid()) @db.Uuid

  /// Matrícula da aeronave (ex.: PR-ZTT). Em `AUTOMATIC`, lida por OCR.
  registration    String   @map("registration")
  /// Confiança da leitura OCR como string (ex.: "0.98"). Não exposta nas rotas
  /// de consulta; só faz sentido para movimentos `AUTOMATIC`.
  confidence      String?  @map("confidence")
  /// Momento da captura/ocorrência do movimento.
  readingDatetime DateTime @map("reading_datetime") @db.Timestamptz(3)

  /// Pouso ou decolagem. Em `AUTOMATIC` é inferido pela regra de 48h; em
  /// `MANUAL` vem do formulário.
  operationType MovementType   @map("operation_type")
  /// Como o registro entrou no sistema (câmera vs interface).
  source        MovementSource @map("source")

  /// Status de validação humana — `null` = ainda não validada.
  readingStatus String? @map("reading_status")
  /// Identificador do revisor (legado `String`; migração para FK `users.id` em PR separado).
  revisorId     String? @map("revisor_id")
  /// Key do objeto no MinIO (ex.: `readings/2026/06/<uuid>.jpg`) — nunca a presigned URL.
  imageKey      String? @map("image_key") @db.Text
  /// Comentários do revisor.
  comments      String? @map("comments") @db.Text
  /// Código ICAO do aeródromo onde o movimento ocorreu (ex.: SSCF).
  aerodrome     String? @map("aerodrome")

  /// Conformidade do movimento perante o pedido de aterragem aprovado. Definida
  /// na criação (`PENDING` quando aplicável; senão `NOT_APPLICABLE`) e resolvida
  /// pelo fluxo de conformidade (`CONFORMANT`/`NON_CONFORMANT`).
  conformityStatus ConformityStatus @default(PENDING) @map("conformity_status")

  /// Snapshot dos dados cadastrais (RAB) da aeronave no instante do movimento.
  aircraftSnapshot MovementAircraftSnapshot?

  /// Eventos operacionais (ex.: não-conformidades) originados deste movimento.
  operationalEvents OperationalEvent[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  /// "Inserido por": id do usuário (MANUAL) ou sentinela (ex.: "aviascan") (AUTOMATIC).
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([registration])
  @@index([aerodrome, readingDatetime])
  @@index([readingDatetime])
  @@index([conformityStatus])
  @@index([deletedAt])
  @@map("movement")
}

/// Snapshot 1:1 dos dados cadastrais da aeronave (tabela RAB da ANAC) congelados
/// no instante do movimento. A `rab_row` é periódica (chave `(period, marcas)`) e
/// o registro "atual" muda a cada período mensal — por isso copiamos um
/// subconjunto curado dos campos aqui, mantendo `rabRowId`/`rabPeriod` apenas
/// para rastreabilidade até a origem. Campos opcionais: a aeronave pode não ter
/// linha RAB correspondente no momento do movimento.
model MovementAircraftSnapshot {
  id String @id @default(uuid()) @db.Uuid

  movementId String   @unique @map("movement_id") @db.Uuid
  movement   Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)

  /// Rastreabilidade até a `rab_row` de origem (id + período), quando havia match.
  rabRowId  String? @map("rab_row_id")
  rabPeriod String? @map("rab_period")

  /// Subconjunto operacional congelado do `rab_row` (todos `String?`, fiéis à origem).
  marcas          String? @map("marcas")
  proprietarios   String? @map("proprietarios")
  operadores      String? @map("operadores")
  nrSerie         String? @map("nr_serie")
  dsModelo        String? @map("ds_modelo")
  nmFabricante    String? @map("nm_fabricante")
  cdTipoIcao      String? @map("cd_tipo_icao")
  nrPmd           String? @map("nr_pmd")
  nrAssentos      String? @map("nr_assentos")
  nrAnoFabricacao String? @map("nr_ano_fabricacao")
  tpMotor         String? @map("tp_motor")
  qtMotor         String? @map("qt_motor")
  cfOperacional   String? @map("cf_operacional")
  tpOperacao      String? @map("tp_operacao")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([rabRowId])
  @@map("movement_aircraft_snapshot")
}

enum OperationalEventType {
  NON_CONFORMITY_NO_LANDING_REQUEST
}

enum OperationalEventStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model OperationalEvent {
  id     String                 @id @default(uuid()) @db.Uuid
  type   OperationalEventType   @map("type")
  status OperationalEventStatus @default(OPEN) @map("status")

  /// Código ICAO do aeródromo do evento.
  aerodrome  String    @map("aerodrome")
  /// Movimento que originou o evento (opcional; SetNull para não perder o evento se o movimento sumir).
  movementId String?   @map("movement_id") @db.Uuid
  movement   Movement? @relation(fields: [movementId], references: [id], onDelete: SetNull)

  /// Quando o fato ocorreu (= readingDatetime do movimento).
  occurredAt DateTime  @map("occurred_at") @db.Timestamptz(3)
  /// Quando o sistema detectou/registrou.
  detectedAt DateTime  @default(now()) @map("detected_at") @db.Timestamptz(3)
  /// Quando a notificação foi enviada (null = ainda não notificado).
  notifiedAt DateTime? @map("notified_at") @db.Timestamptz(3)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([aerodrome, occurredAt])
  @@index([type, status])
  @@index([movementId])
  @@index([deletedAt])
  @@map("operational_event")
}

/// Visita técnica em aeródromo (`technicalVisit` no Firestore). ICAO, CIAD, pista, nome e município do aeródromo vêm de `aerodromes` via FK (evita duplicar o cadastro).
model TechnicalVisit {
  id          String    @id @default(uuid()) @db.Uuid
  aerodromeId String    @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Restrict)

  /// Uids Auth (preferencial) ou e-mail na importação legada — quem editou a visita, em ordem. Firestore ainda usa objetos `{ name, email, date }?` até cutover.
  modifierUsers String[] @default([]) @map("modifier_users")

  gatesPadlocksObservation          String?  @map("gates_padlocks_observation") @db.Text
  hasGatesPadlocks                  Boolean? @map("has_gates_padlocks")
  fenceObservation                  String?  @map("fence_observation") @db.Text
  hasFence                          Boolean? @map("has_fence")
  standardPlateObservation          String?  @map("standard_plate_observation") @db.Text
  hasStandardPlate                  Boolean? @map("has_standard_plate")
  qualityObservation                String?  @map("quality_observation") @db.Text
  qualityOthersObservation          String?  @map("quality_others_observation") @db.Text
  hasQualityHoles                   Boolean? @map("has_quality_holes")
  hasQualityAsphalt                 Boolean? @map("has_quality_asphalt")
  hasQualityOthers                  Boolean? @map("has_quality_others")
  horizontalSignageObservation      String?  @map("horizontal_signage_observation") @db.Text
  hasHorizontalSignage              Boolean? @map("has_horizontal_signage")
  unobstructedHeadboardsObservation String?  @map("unobstructed_headboards_observation") @db.Text
  hasUnobstructedHeadboards         Boolean? @map("has_unobstructed_headboards")
  trackRangeObservation             String?  @map("track_range_observation") @db.Text
  hasTrackRange                     Boolean? @map("has_track_range")
  pavementRegularity                Boolean? @map("pavement_regularity")
  trashDebrisObservation            String?  @map("trash_debris_observation") @db.Text
  hasTrashDebris                    Boolean? @map("has_trash_debris")
  delimitedPerimeterObservation     String?  @map("delimited_perimeter_observation") @db.Text
  hasDelimitedPerimeter             Boolean? @map("has_delimited_perimeter")
  hasInvasion                       Boolean? @map("has_invasion")
  extraObservation                  String?  @map("extra_observation") @db.Text

  visitAt DateTime @map("visit_at") @db.Timestamptz(3)
  /// Firebase Auth uid de quem realizou a visita. Migração desse campo para FK ao `users.id` fica em PR separado. Legado Firestore: `VISITORNAME` até cutover; import pode deixar null.
  visitBy String?  @map("visit_by")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([aerodromeId, visitAt])
  @@map("technical_visits")
}

/// GeoJSON operacional inline (1:1 com o aeródromo; equivale a um doc na coleção `geojsons` no Firestore).
model Geojson {
  id String @id @default(uuid()) @db.Uuid

  /// Um registro por aeródromo operacional.
  aerodromeId String    @unique @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Restrict)

  /// Mantido para compatibilidade conceitual (ex.: `aerodrome_map`); o vínculo é único via `aerodrome_id`.
  kind   GeojsonKind
  status GeojsonStatus

  /// GeoJSON RFC 7946 (jsonb). Opcional quando `status` = ERROR sem payload inline.
  geoJson      Json?               @map("geo_json")
  geoJsonBytes Int                 @default(0) @map("geo_json_bytes")
  featureCount Int                 @default(0) @map("feature_count")
  mapFileType  GeojsonMapFileType? @map("map_file_type")

  sourceStoragePath  String? @map("source_storage_path") @db.Text
  sourceUpdatedAt    String? @map("source_updated_at")
  geoJsonStoragePath String? @map("geo_json_storage_path") @db.Text
  versionHash        String? @map("version_hash")
  errorMessage       String? @map("error_message") @db.Text
  processingMs       Int?    @map("processing_ms")
  sourceBytes        Int?    @map("source_bytes")
  kmlTextBytes       Int?    @map("kml_text_bytes")
  zipBytes           Int?    @map("zip_bytes")

  generatedAt DateTime? @map("generated_at") @db.Timestamptz(3)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([status])
  @@map("geojsons")
}

/// Documento de aeródromo (coleção plana `documents` no Firestore). Arquivo no
/// object storage (MinIO, domínio `aerodromes`); persiste só a **key**
/// (`storageKey`), presigned resolvida on-read. Múltiplos por tipo coexistem; a
/// regra "1 ativo" vale só para o `upload-aerodrome-file` (kml/image).
model Document {
  id          String    @id @default(uuid()) @db.Uuid
  aerodromeId String    @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Restrict)

  /// Redundância de índice (espelha o `uf` do Firestore), derivada do aeródromo.
  uf   String?      @map("uf")
  type DocumentType

  /// Key MinIO `aerodromes/{aerodromeId}/{docType}/{uuid}-{slug}` (nunca a URL).
  storageKey       String  @map("storage_key") @db.Text
  originalFilename String  @map("original_filename")
  mimeType         String  @map("mime_type")
  sizeBytes        Int     @map("size_bytes")
  uploadedBy       String? @map("uploaded_by")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([aerodromeId])
  @@index([aerodromeId, type, deletedAt])
  @@map("documents")
}

/// Avaliação pública (subcoleção `feedbacks` no Firestore).
model Feedback {
  id          String    @id @default(uuid()) @db.Uuid
  aerodromeId String    @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Restrict)

  rating       FeedbackRating @map("rating")
  comment      String?        @map("comment") @db.Text
  sessionHash  String         @map("session_hash")
  /// Dia da avaliação (rate limit diário alinhado ao Firestore `date` YYYY-MM-DD).
  feedbackDate DateTime       @map("feedback_date") @db.Date

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@unique([sessionHash, aerodromeId, feedbackDate])
  @@index([aerodromeId, feedbackDate])
  @@map("feedbacks")
}

/// Tipos de token genérico usados pelo módulo `tokens` (email verification,
/// password reset, OTP, convite de novo usuário, etc).
/// Modelagem genérica via `subject_id: String`; quando o token é emitido
/// no contexto de um usuário (INVITE, EMAIL_VERIFICATION, PASSWORD_RESET)
/// também é populada a FK opcional `user_id` para integridade referencial.
enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  OTP
  GENERIC
  INVITE
}

/// Token de uso único (one-shot) com hash bcrypt no campo `token_hash`.
/// O token plain é enviado ao usuário (email, SMS, etc.) e jamais persistido.
/// Validação confere: hash bate + não expirou + não usado + não soft-deleted.
model Token {
  id        String    @id @default(uuid()) @db.Uuid
  type      TokenType @map("type")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  used      Boolean   @default(false)
  metadata  Json?
  subjectId String    @map("subject_id")

  /// FK opcional ao usuário dono do token (INVITE/EMAIL_VERIFICATION/PASSWORD_RESET).
  /// Para OTP/GENERIC permanece null — `subject_id` cobre escopos não-User.
  userId String? @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([type])
  @@index([tokenHash])
  @@index([subjectId, type])
  @@index([userId, type])
  @@index([deletedAt])
  @@map("tokens")
}

/// Registro de pouso do piloto (coleção raiz `landings` no Firestore).
model PilotLanding {
  id          String     @id @default(uuid()) @db.Uuid
  aerodromeId String?    @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome? @relation(fields: [aerodromeId], references: [id], onDelete: SetNull)

  registration String   @map("registration")
  localName    String   @map("local_name")
  localIcao    String   @map("local_icao")
  checked      Boolean  @map("checked")
  imagesPath   String   @map("images_path")
  /// Instante do pouso informado pelo piloto (UTC). Migração: parse do legado Firestore `date`.
  landingAt    DateTime @map("landing_at") @db.Timestamptz(3)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([aerodromeId])
  @@index([registration])
  @@map("pilot_landings")
}

// =============================================================================
// Autenticação e usuários (Aerobi). Espelha o conjunto de roles usado no
// `aerobi-web` (admin/coordinator/operator/technical) em UPPERCASE. Senha
// nullable até o convite ser aceito; criação pública não existe — apenas
// ADMIN convida via fluxo Token tipo INVITE (módulo `tokens`).
// =============================================================================

/// Papéis de usuário (espelha as roles já gateadas pelo `aerobi-web`).
enum UserRole {
  ADMIN
  COORDINATOR
  OPERATOR
  TECHNICAL
}

/// Usuário humano da Aerobi (convidado por ADMIN; não há signup público).
model User {
  id String @id @default(uuid()) @db.Uuid

  email         String    @unique
  name          String
  phone         String?
  /// Hash bcrypt — null enquanto o convite não foi aceito.
  password      String?
  role          UserRole  @default(OPERATOR)
  emailVerified Boolean   @default(false) @map("email_verified")
  timezone      String?   @db.VarChar(64)
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz(3)

  /// Grupo de aeródromos ao qual o usuário pertence (escopo). ADMIN global
  /// fica `null` (bypass por role, não pela sentinela "admin" do Firestore).
  groupId String? @map("group_id") @db.Uuid
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  /// UF de atuação do usuário (espelha `state` do Firestore).
  state   Uf?

  /// ADMIN que originou o convite (self-relation).
  invitedById      String?   @map("invited_by_id") @db.Uuid
  invitedBy        User?     @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitees         User[]    @relation("UserInvites")
  invitedAt        DateTime? @map("invited_at") @db.Timestamptz(3)
  acceptedInviteAt DateTime? @map("accepted_invite_at") @db.Timestamptz(3)

  refreshTokens RefreshToken[]
  tokens        Token[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([email])
  @@index([role])
  @@index([groupId])
  @@index([deletedAt])
  @@map("users")
}

/// Refresh token persistido (hash SHA-256 do plain). `jti` único permite
/// rotação encadeada — quando rotacionado, `replacedById` aponta ao sucessor
/// e o registro antigo fica `revoked=true`. Reuso de refresh já revogado
/// detecta sequestro e revoga toda a família via service.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  jti       String    @unique
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revoked   Boolean   @default(false)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)

  /// Próximo refresh emitido a partir deste (rotação encadeada).
  replacedById String? @map("replaced_by_id") @db.Uuid

  userAgent String? @map("user_agent")
  ipAddress String? @map("ip_address")

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([userId])
  @@index([jti])
  @@index([deletedAt])
  @@map("refresh_tokens")
}

/// Imagem (logo/capa) de um grupo de aeródromo, armazenada no MinIO sob o
/// prefixo `groups/{groupId}/images/`. No máximo uma ativa por grupo (garantido
/// na transação de upload, que soft-deleta as anteriores). Persiste a key do
/// objeto; a URL presigned é resolvida on-read.
model GroupImage {
  id               String  @id @default(uuid()) @db.Uuid
  groupId          String  @map("group_id") @db.Uuid
  group            Group   @relation(fields: [groupId], references: [id], onDelete: Restrict)
  imageKey         String  @map("image_key") @db.Text
  originalFilename String  @map("original_filename")
  mimeType         String  @map("mime_type")
  sizeBytes        Int     @map("size_bytes")
  uploadedBy       String? @map("uploaded_by")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([groupId])
  @@map("group_images")
}

// =============================================================================
// Manutenções (`maintenances` + `maintenance_tasks` + `maintenance_guesses`).
// Espelha as coleções planas do `aerobi-web` (intervenção → tarefas → palpites).
// Escopo por grupo resolve-se via aeródromo dono; acesso público de stakeholders
// usa `security_code` + `authorized_emails` (fora do RBAC JWT).
// =============================================================================

enum TaskStatus {
  PENDING
  COMPLETED

  @@map("task_status")
}

enum TaskUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("task_urgency")
}

enum TaskFollowUp {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PAUSED

  @@map("task_follow_up")
}

enum InvestmentType {
  CAPEX
  OPEX

  @@map("investment_type")
}

enum GuessStatus {
  PENDING
  CONSIDERED
  DISMISSED

  @@map("guess_status")
}

/// Intervenção de manutenção ligada a um aeródromo operacional.
model Maintenance {
  id          String    @id @default(uuid()) @db.Uuid
  aerodromeId String    @map("aerodrome_id") @db.Uuid
  aerodrome   Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Restrict)

  name             String
  /// Null ou vazio desabilita o acesso público por link.
  securityCode     String?  @map("security_code")
  authorizedEmails String[] @map("authorized_emails")

  tasks MaintenanceTask[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([aerodromeId])
  @@map("maintenances")
}

/// Tarefa de uma intervenção de manutenção.
model MaintenanceTask {
  id            String      @id @default(uuid()) @db.Uuid
  maintenanceId String      @map("maintenance_id") @db.Uuid
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Restrict)

  title                 String
  description           String          @db.Text
  predictedValue        Decimal         @map("predicted_value") @db.Decimal(14, 2)
  insertionDate         DateTime        @map("insertion_date") @db.Timestamptz(3)
  predictedDate         DateTime        @map("predicted_date") @db.Timestamptz(3)
  completionDate        DateTime?       @map("completion_date") @db.Timestamptz(3)
  actualCost            Decimal?        @map("actual_cost") @db.Decimal(14, 2)
  completionDescription String?         @map("completion_description") @db.Text
  impact                String?         @db.Text
  timeElapsed           String?         @map("time_elapsed")
  status                TaskStatus      @default(PENDING)
  urgency               TaskUrgency?
  followUp              TaskFollowUp?   @map("follow_up")
  investmentType        InvestmentType? @map("investment_type")
  responsibility        String?
  delayWarning          Boolean?        @map("delay_warning")

  guesses MaintenanceGuess[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([maintenanceId])
  @@map("maintenance_tasks")
}

/// Palpite/sugestão pública associado a uma tarefa (coleção `guesses` no web).
model MaintenanceGuess {
  id     String          @id @default(uuid()) @db.Uuid
  taskId String          @map("task_id") @db.Uuid
  task   MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Restrict)

  text   String      @db.Text
  email  String
  status GuessStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([taskId])
  @@index([status])
  @@map("maintenance_guesses")
}

// =============================================================================
// Fale conosco (`contact`). Espelha a coleção Firestore homônima do `aerobi-web`:
// formulário público (`POST /contact`, X-API-Key) com comprovante por e-mail,
// anti-abuso (honeypot, tempo mínimo de preenchimento, rate limit por
// session_hash/e-mail/IP e chave `date` UTC) e moderação admin (listagem, export
// CSV, status `pending`/`resolved`, soft-delete). Enums em lowercase para paridade
// 1:1 com o web (`ContactType`, `ContactMessageStatus`).
// =============================================================================

/// Tipo da mensagem no formulário (espelha `type` na coleção `contact`).
enum ContactType {
  complaint
  question
  suggestion
  other
}

/// Situação de triagem pela equipe admin (espelha `status` no Firestore).
enum ContactMessageStatus {
  pending
  resolved
}

/// Mensagem do formulário público "Fale conosco" (coleção raiz `contact` no
/// Firestore). `createdBy` permanece null em submissões públicas; `updatedBy` e
/// `deletedBy` são preenchidos na moderação. `sessionHash` e `ipHash` são hashes
/// anônimos para rate limit diário — não identificam o autor (LGPD).
model Contact {
  id          String               @id @default(uuid()) @db.Uuid
  email       String
  name        String
  phone       String
  message     String               @db.Text
  type        ContactType
  status      ContactMessageStatus @default(pending)
  /// Hash estável da sessão do navegador (SHA-256 hex); par com `date` no índice anti-spam.
  sessionHash String?              @map("session_hash")
  /// Chave de rate-limit UTC (`YYYY-MM-DD`), espelha Firestore `date`.
  date        String
  /// Hash do IP do cliente para rate limit diário; par com `date` no índice anti-spam.
  ipHash      String?              @map("ip_hash")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by")

  @@index([deletedAt])
  @@index([status])
  @@index([type])
  @@index([sessionHash, date])
  @@index([email, date])
  @@index([ipHash, date])
  @@index([createdAt])
  @@map("contact")
}

// =============================================================================
// Auditoria (audit log). Trilha **append-only** das ações de escrita
// (CREATE/UPDATE/DELETE) sobre entidades do domínio — paridade com a coleção
// `auditLogs` do `aerobi-web` (Firestore). Gravada internamente pelo
// `AuditRecorderService` em cada mutação (best-effort: falha de auditoria nunca
// derruba a ação de negócio). Diverge de propósito do padrão soft-delete dos
// demais models: um log não se edita nem se apaga (é o ponto da trilha), então
// só há `createdAt`. Sub-operações (SET_STATUS, DECIDE, RESET_PASSWORD, …) não
// viram novas actions — entram em `metadata` (ex.: `{ scope: 'reset-password' }`),
// como no web.
// =============================================================================

/// Ação auditada (espelha `auditActionEnum` do `aerobi-web`). Só o núcleo
/// CREATE/UPDATE/DELETE; nuances de sub-operação vão em `AuditLog.metadata`.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

/// Registro de auditoria append-only (espelha a coleção `auditLogs` do
/// Firestore). Os campos `actor*` são **snapshot** no momento da ação:
/// `actorId` sem FK rígida para `users.id` por ora (mesmo tratamento do uid
/// Firebase legado — ver AGENTS.md) e nullable para cobrir ação pública/
/// sistêmica (ex.: pedido de pouso criado sem login). `before`/`after` são
/// recortes parciais (só os campos relevantes) e `metadata` guarda pares extras
/// (`groupId`/`uf`/`scope`/…) usados para rastreio.
model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  actorId    String?   @map("actor_id")
  actorEmail String?   @map("actor_email")
  actorRole  UserRole? @map("actor_role")

  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")

  before   Json?
  after    Json?
  metadata Json?

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([entityType, entityId, createdAt])
  @@index([actorEmail])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
