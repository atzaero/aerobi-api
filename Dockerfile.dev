FROM node:22-bookworm-slim

# Prisma: node:*-slim images omit OpenSSL; install for correct engine detection.
# https://www.prisma.io/docs/guides/docker
RUN apt-get update -y \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app
COPY package*.json ./
# postinstall runs prisma generate — schema + config must exist before npm install
COPY prisma ./prisma/
COPY prisma.config.ts ./
RUN npm install
COPY . .
RUN chmod +x scripts/start-dev.sh
EXPOSE 3333
CMD ["./scripts/start-dev.sh"]
