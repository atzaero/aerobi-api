# App
NODE_ENV=development
# Com NODE_ENV=development, POST /rab/sync não exige Bearer nem X-API-Key (FirebaseOrApiKeyGuard bypass).
# Para testar auth localmente: RAB_SYNC_REQUIRE_AUTH=true
# RAB_SYNC_REQUIRE_AUTH=false
PORT=3333
CORS_ORIGINS=http://localhost:3000

# Docker dev + nest start --watch com bind mount: o compose define estes valores para o serviço api.
# Não são lidos pelo Nest; o Chokidar (watcher) usa-os para reduzir eventos duplicados e EADDRINUSE na PORT.
# CHOKIDAR_USEPOLLING=true
# CHOKIDAR_INTERVAL=800
#
# Overrides opcionais do docker-compose.dev.yml (caminhos de volume; omitir = defaults do compose):
# VOLUME_APP_SOURCE=./
# VOLUME_APP_NODE_MODULES=aerobi_api_node_modules_dev

# Postgres (host "postgres" dentro do Docker Compose; "localhost" se Nest roda na máquina)
POSTGRES_USER=aerobi
POSTGRES_PASSWORD=aerobi
POSTGRES_DB=aerobi
POSTGRES_EXTERNAL_PORT=5432
DATABASE_URL=postgresql://aerobi:aerobi@localhost:5432/aerobi?schema=public

# ANAC RAB (dados abertos)
ANAC_RAB_INDEX_URL=https://sistemas.anac.gov.br/dadosabertos/Aeronaves/RAB/Historico_RAB/
HTTP_USER_AGENT=aerobi-api/1.0 (ANAC dados abertos RAB)

# Sync agendado (cron). Desative com RAB_SYNC_CRON_DISABLED=true
# RAB_SYNC_CRON=0 5 * * *
# RAB_SYNC_CRON_DISABLED=false

# ---------------------------------------------------------------------------
# Auth para POST /rab/sync (FirebaseOrApiKeyGuard no SyncController)
# ---------------------------------------------------------------------------
#
# Com NODE_ENV=development o guard faz bypass nesta rota (sem Bearer / X-API-Key), salvo RAB_SYNC_REQUIRE_AUTH=true.
#
# O cliente pode autenticar de DUAS formas (quando o bypass não se aplica; o guard aceita a que satisfizer):
#
# A) X-API-Key — chave partilhada (scripts, CI, operador sem Firebase)
#    - Define RAB_SYNC_API_KEY abaixo (valor secreto, longo e aleatório).
#    - Pedido: header X-API-Key com o mesmo valor.
#
# B) Firebase ID token — utilizador já com sessão Firebase no frontend
#    - Frontend: após login Firebase Auth, user.getIdToken().
#    - Pedido: Authorization: Bearer <id_token>  (é um JWT emitido pelo Firebase, não pela Nest API).
#    - Backend: FIREBASE_PROJECT_ID + credenciais de service account para o Admin SDK validar o token.
#
# FIREBASE_PROJECT_ID=your-gcp-project-id
# Opcional: JSON inline da service account (uma linha, escapado) OU ficheiro via ADC:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# Só necessário se usares a via A (senão deixa vazio):
RAB_SYNC_API_KEY=

# ---------------------------------------------------------------------------
# Produção (docker-compose.prod.yml + rede Docker warpgate no servidor)
# ---------------------------------------------------------------------------
#
# A rede Docker **warpgate** é a partilhada com Postgres e outras apps (Ansible).
# Não é o binário Warpgate — apenas o nome da bridge `docker network create warpgate`.
#
# No .env do servidor (ou secrets do GitHub Actions deploy.yml), define também:
#
# REGISTRY=ghcr.io
# IMAGE_NAME=<owner>/<repo>   # ex.: mesmo nome do repositório GitHub (minúsculas)
# TAG=<versão semântica>      # preenchido pelo deploy a partir da release
#
# NODE_ENV=production
# PORT=3333
#
# DATABASE_URL=postgresql://USER:PASS@postgres:5432/DB_AEROBI?schema=public
#   ^ host `postgres` = nome do container PostgreSQL na rede warpgate (ver ansible-vps docs).
#
# CORS_ORIGINS=https://teu-dominio.com
#
# GitHub Actions — secrets úteis para deploy.yml:
#   SSH_PRIVATE_KEY, REMOTE_HOST, REMOTE_PORT, REMOTE_USER, REMOTE_TARGET,
#   GH_TOKEN (read:packages + uso no release: repo),
#   DATABASE_URL, CORS_ORIGINS,
#   APP_PORT (opcional; default 3333),
#   ANAC_RAB_INDEX_URL, HTTP_USER_AGENT, RAB_SYNC_*, FIREBASE_* (opcionais)
#
# FIREBASE_SERVICE_ACCOUNT_JSON no secret deve ser UMA linha (JSON minificado) para o .env gerado.
