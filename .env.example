# =============================================================================
# aerobi-api — variáveis de ambiente (copie para .env e preencha os segredos)
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3333
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Desenvolvimento (Docker / watcher — não lidos pelo Nest)
# -----------------------------------------------------------------------------
# Chokidar (nest start --watch + bind mount): reduz eventos duplicados / EADDRINUSE.
# O docker-compose.dev define estes valores no serviço api.
# CHOKIDAR_USEPOLLING=true
# CHOKIDAR_INTERVAL=800
#
# Overrides opcionais do docker-compose.dev.yml (omitir = defaults do compose):
# VOLUME_APP_SOURCE=./
# VOLUME_APP_NODE_MODULES=aerobi_api_node_modules_dev

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Host: "postgres" dentro do Docker Compose; "localhost" se o Nest roda na máquina.
POSTGRES_USER=aerobi
POSTGRES_PASSWORD=aerobi
POSTGRES_DB=aerobi
POSTGRES_EXTERNAL_PORT=5432
DATABASE_URL=postgresql://aerobi:aerobi@localhost:5432/aerobi?schema=public

# -----------------------------------------------------------------------------
# ANAC — RAB (dados abertos)
# -----------------------------------------------------------------------------
ANAC_RAB_INDEX_URL=https://sistemas.anac.gov.br/dadosabertos/Aeronaves/RAB/Historico_RAB/
HTTP_USER_AGENT=aerobi-api/1.0 (ANAC dados abertos RAB)

# Sincronização agendada (cron). Desative com RAB_SYNC_CRON_DISABLED=true
# RAB_SYNC_CRON=0 5 * * *
# RAB_SYNC_CRON_DISABLED=false

# -----------------------------------------------------------------------------
# ANAC — Aeródromos privados (CSV)
# -----------------------------------------------------------------------------
ANAC_PRIVATE_AERODROMES_CSV_URL=https://sistemas.anac.gov.br/dadosabertos/Aerodromos/Aer%C3%B3dromos%20Privados/Lista%20de%20aer%C3%B3dromos%20privados/Aerodromos%20Privados/AerodromosPrivados.csv

# PRIVATE_AERODROMES_SYNC_CRON=10 5 * * *
# PRIVATE_AERODROMES_SYNC_CRON_DISABLED=false

# -----------------------------------------------------------------------------
# Autenticação HTTP (AerobiApiKeyGuard — /rab/*, /private-aerodromes/*, /plugfield/*)
# -----------------------------------------------------------------------------
# Header quando o bypass não se aplica: X-API-Key = valor de AEROBI_API_KEY.
# Bypass: NODE_ENV=development e AEROBI_REQUIRE_AUTH não truthy.
AEROBI_API_KEY=
# AEROBI_REQUIRE_AUTH=false

# -----------------------------------------------------------------------------
# AISWEB / DECEA (proxy — credenciais só no servidor; o cliente não as envia)
# -----------------------------------------------------------------------------
# Aerobi → AISWEB: apiKey e apiPass. Fallback entre mil.br e gov.br automático.
AISWEB_API_KEY=
AISWEB_API_PASS=

# AISWEB_HTTP_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# Plugfield (proxy — credenciais só no servidor; o cliente não as envia)
# -----------------------------------------------------------------------------
# Aerobi → Plugfield: x-api-key e Authorization (Bearer). O servidor prefixa Bearer se faltar.
PLUGFIELD_API_KEY=
PLUGFIELD_TOKEN=

# PLUGFIELD_API_BASE_URL=https://prod-api.plugfield.com.br
# PLUGFIELD_HTTP_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# AviaScan (proxy — leituras de matrículas; credencial opcional só no servidor)
# -----------------------------------------------------------------------------
# Aerobi → AviaScan: AVIASCAN_API_KEY (opcional) enviada como header x-api-key.
# O cliente da Aerobi continua a autenticar só com X-API-Key = AEROBI_API_KEY.
# AVIASCAN_API_KEY=
# AVIASCAN_API_BASE_URL=https://aviascanapi.lmpierin.com.br
# AVIASCAN_HTTP_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Chave AES-256-GCM usada pelo EncryptionService.
# Aceita hex de 64 chars (32 bytes) ou string de exatamente 32 bytes.
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# JWT (módulo auth — RS256)
# -----------------------------------------------------------------------------
# Par RSA assimétrico. Geração local:
#   openssl genrsa -out jwt-private.pem 4096
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#   # Codificar em base64 (linha única) para colar nas envs:
#   base64 -w0 jwt-private.pem
#   base64 -w0 jwt-public.pem
JWT_SECRET_PUBLIC_KEY=
JWT_SECRET_PRIVATE_KEY=

# TTL do access token (formato `ms` — ex: 15m, 1h, 30s).
JWT_ACCESS_TTL=15m

# TTL do refresh token (ex: 7d, 30d).
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------------------------
# Autenticação interna (users + convite + reset de senha)
# -----------------------------------------------------------------------------
# URL pública do frontend — usada para montar links de convite/reset enviados
# por email (ex: ${FRONTEND_URL}/accept-invite?token=...).
FRONTEND_URL=http://localhost:3000

# TTL do token de convite (horas).
INVITE_TTL_HOURS=72

# TTL do token de redefinição de senha (horas).
PASSWORD_RESET_TTL_HOURS=2

# -----------------------------------------------------------------------------
# Seeds (orquestrador em scripts/seeds — `npm run seed` ou `npm run seed:users`)
# -----------------------------------------------------------------------------
# `RUN_SEEDS_ON_BOOT` controla se o seed roda automaticamente após
# `prisma migrate deploy` no boot:
#   - Dev (start-dev.sh):  default **true**  — seed roda sempre que
#     houver `SEED_USER_*` configurado. Setar `=false` para desligar.
#   - Prod (start-prod.sh): default **false** — operator dispara
#     manualmente (`node dist/scripts/run-seeds.js`). Setar `=true`
#     temporariamente só no bootstrap inicial.
# Idempotente — pode rodar em todo boot sem efeito colateral.
# RUN_SEEDS_ON_BOOT=true

# Lista de usuários a aplicar via seed `users` (idempotente, upsert por email).
# Adicione blocos incrementando o índice — o parser para no primeiro
# SEED_USER_<N>_EMAIL ausente. Cada bloco precisa de email, password
# (>= 8 chars), name e role (ADMIN | COORDINATOR | OPERATOR | TECHNICAL).
#
# Sem signup público na Aerobi, este é o único caminho para destravar
# o sistema — defina pelo menos um usuário com role ADMIN.
SEED_USER_1_EMAIL=admin@aerobi.local
SEED_USER_1_PASSWORD=AdmTrocar123!
SEED_USER_1_NAME=Admin
SEED_USER_1_ROLE=ADMIN

# Exemplo de segundo usuário (descomente e ajuste para usar):
SEED_USER_2_EMAIL=coordenador@aerobi.local
SEED_USER_2_PASSWORD=CoordTrocar123!
SEED_USER_2_NAME=Coordenador
SEED_USER_2_ROLE=COORDINATOR

# -----------------------------------------------------------------------------
# Email (EmailService / @nestjs-modules/mailer)
# -----------------------------------------------------------------------------
# Em NODE_ENV=development o EmailService usa Ethereal (https://ethereal.email):
#   - Se ETHEREAL_USERNAME / ETHEREAL_PASSWORD estiverem definidos, usa essa conta;
#   - Caso contrário, cria uma conta temporária automaticamente (expira em 48h).
# Em produção, use SMTP real — MAIL_HOST/MAIL_USER/MAIL_PASS são obrigatórios.
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
MAIL_USER_NO_REPLY=noreply@aerobi.local

# Development only (opcional — sem isto usa createTestAccount automático)
ETHEREAL_USERNAME=
ETHEREAL_PASSWORD=

# -----------------------------------------------------------------------------
# Referência — produção (docker-compose.prod.yml + rede Docker warpgate)
# -----------------------------------------------------------------------------
# A rede **warpgate** é a bridge partilhada com Postgres e outras apps (Ansible),
# não o binário Warpgate (`docker network create warpgate`).
#
# No servidor (.env ou secrets do deploy), além das variáveis acima:
#
#   NODE_ENV=production
#   PORT=3333
#   DATABASE_URL=postgresql://USER:PASS@postgres:5432/DB_AEROBI?schema=public
#     (host `postgres` = container PostgreSQL na rede warpgate)
#   CORS_ORIGINS=https://teu-dominio.com
#
# Build / imagem (exemplos):
#   REGISTRY=ghcr.io
#   IMAGE_NAME=<owner>/<repo>
#   TAG=<versão semântica>
#
# GitHub Actions (deploy.yml) — secrets típicos:
#   SSH_PRIVATE_KEY, REMOTE_HOST, REMOTE_PORT, REMOTE_USER, REMOTE_TARGET,
#   GH_TOKEN (read:packages + release: repo),
#   DATABASE_URL, CORS_ORIGINS, APP_PORT (opcional; default 3333),
#   ANAC_RAB_INDEX_URL, HTTP_USER_AGENT,
#   AEROBI_API_KEY (substitui o antigo RAB_SYNC_API_KEY; não usar mais esse nome no GitHub),
#   AEROBI_REQUIRE_AUTH (opcional),
#   PLUGFIELD_API_KEY, PLUGFIELD_TOKEN (proxy Plugfield no servidor),
#   PLUGFIELD_API_BASE_URL, PLUGFIELD_HTTP_TIMEOUT_MS (opcionais),
#   RAB_SYNC_CRON, RAB_SYNC_CRON_DISABLED (opcional; só agendamento, não auth)
