# =============================================================================
# aerobi-api — variáveis de ambiente (copie para .env e preencha os segredos)
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3333
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Desenvolvimento (hot reload — só em NODE_ENV=development)
# -----------------------------------------------------------------------------
# Hot reload usa Webpack HMR (`nest build --webpack ... --watch`): recompila e
# troca módulos no MESMO processo, sem reiniciar — elimina a corrida de EADDRINUSE.
#
# Rede de segurança: retry do bind da porta (só em EADDRINUSE; resíduo transitório
# do watcher). Defaults: 10 tentativas, 400ms base com backoff 1.5x até 3500ms.
# LISTEN_RETRY_MAX=10
# LISTEN_RETRY_DELAY_MS=400

# -----------------------------------------------------------------------------
# PostgreSQL (provido pela infra local aerobi-local-infra — porta host 5433)
# -----------------------------------------------------------------------------
# Os serviços de dado vêm do projeto atzaero/aerobi-local-infra (`make up`).
# `POSTGRES_*` devem casar com o app `aerobi` criado lá (AEROBI_DB_PASSWORD).
# Host: "aerobi-postgres" dentro do compose (o docker-compose.dev.yml já injeta
# isso); "localhost:5433" quando o Nest roda direto na máquina.
POSTGRES_USER=aerobi
POSTGRES_PASSWORD=aerobi
POSTGRES_DB=aerobi
DATABASE_URL=postgresql://aerobi:aerobi@localhost:5433/aerobi?schema=public

# -----------------------------------------------------------------------------
# ANAC — RAB (dados abertos)
# -----------------------------------------------------------------------------
ANAC_RAB_INDEX_URL=https://sistemas.anac.gov.br/dadosabertos/Aeronaves/RAB/Historico_RAB/
HTTP_USER_AGENT=aerobi-api/1.0 (ANAC dados abertos RAB)

# Sincronização agendada (cron). Desative com RAB_SYNC_CRON_DISABLED=true
# RAB_SYNC_CRON=0 5 * * *
# RAB_SYNC_CRON_DISABLED=false

# -----------------------------------------------------------------------------
# ANAC — Aeródromos privados (CSV)
# -----------------------------------------------------------------------------
ANAC_PRIVATE_AERODROMES_CSV_URL=https://sistemas.anac.gov.br/dadosabertos/Aerodromos/Aer%C3%B3dromos%20Privados/Lista%20de%20aer%C3%B3dromos%20privados/Aerodromos%20Privados/AerodromosPrivados.csv

# PRIVATE_AERODROMES_SYNC_CRON=10 5 * * *
# PRIVATE_AERODROMES_SYNC_CRON_DISABLED=false

# -----------------------------------------------------------------------------
# Autenticação HTTP (AerobiApiKeyGuard — /rab/*, /private-aerodromes/*, /plugfield/*)
# -----------------------------------------------------------------------------
# Header quando o bypass não se aplica: X-API-Key = valor de AEROBI_API_KEY.
# Bypass: NODE_ENV=development e AEROBI_REQUIRE_AUTH não truthy.
AEROBI_API_KEY=
# AEROBI_REQUIRE_AUTH=false

# -----------------------------------------------------------------------------
# AISWEB / DECEA (proxy — credenciais só no servidor; o cliente não as envia)
# -----------------------------------------------------------------------------
# Aerobi → AISWEB: apiKey e apiPass. Fallback entre mil.br e gov.br automático.
AISWEB_API_KEY=
AISWEB_API_PASS=

# AISWEB_HTTP_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# Plugfield (proxy — credenciais só no servidor; o cliente não as envia)
# -----------------------------------------------------------------------------
# Aerobi → Plugfield: x-api-key e Authorization (Bearer). O servidor prefixa Bearer se faltar.
PLUGFIELD_API_KEY=
PLUGFIELD_TOKEN=

# PLUGFIELD_API_BASE_URL=https://prod-api.plugfield.com.br
# PLUGFIELD_HTTP_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# MinIO / Object storage (módulo storage — imagens dos movimentos/leituras)
# -----------------------------------------------------------------------------
# Provider de storage (default: minio).
# STORAGE_PROVIDER=minio
# Endpoint interno (upload/delete/download): "aerobi-minio:9000" na rede aerobi-local
# (o docker-compose.dev.yml já injeta); em prod a rede warpgate.
MINIO_ENDPOINT=http://aerobi-minio:9000
# Endpoint público usado SÓ para assinar presigned URLs (host acessível ao navegador).
# Dev (aerobi-local-infra): http://localhost:9002 | staging/prod: https://s3.aerobi.com.br
MINIO_PUBLIC_ENDPOINT=http://localhost:9002
# Casam com o aerobi-local-infra (MINIO_ROOT_USER / MINIO_ROOT_PASSWORD).
MINIO_ACCESS_KEY=aerobi-admin
MINIO_SECRET_KEY=minio_dev_only
# Bucket único por app/ambiente: aerobi-{dev,staging,prod}. O storage espelha o
# banco por prefixo de entidade (groups/, movements/, …).
MINIO_BUCKET=aerobi-dev
# MINIO_REGION=sa-east-1

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Chave AES-256-GCM usada pelo EncryptionService.
# Aceita hex de 64 chars (32 bytes) ou string de exatamente 32 bytes.
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Firebase Admin (Firestore — fluxo de conformidade #248/#249)
# -----------------------------------------------------------------------------
# Credenciais de service account para leitura do Firestore (coleções planas:
# landing_requests, aerodromes, users, cameras). Init resiliente: se ausentes, o
# boot segue e o Firestore só falha quando efetivamente usado (feature desligada).
# Projetos: dev `aerobi-atz-dev-e3141`, prod `aerobi-atz`.
FIREBASE_PROJECT_ID=aerobi-atz-dev-e3141
FIREBASE_CLIENT_EMAIL=
# Chave privada do service account. Mantenha os `\n` literais entre aspas — o
# código substitui `\n` por quebras de linha reais.
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Conformidade (movimentos × solicitações de pouso — #252/#253)
# -----------------------------------------------------------------------------
# A cada pouso automático (aviascan), o ConformityListener procura uma
# solicitação de pouso aprovada no Firestore; sem match, regista uma
# não-conformidade e o NotificationListener notifica os contactos do aeródromo.
# Ver src/modules/conformity/README.md.
#
# Janela (horas) para casar o pouso com uma solicitação aprovada: compara
# request_date com o instante do pouso em ±N horas. Default 24.
# CONFORMITY_MATCH_WINDOW_HOURS=24
#
# Janela (minutos) de dedupe das notificações por (matrícula, aeródromo):
# dentro dela, uma não-conformidade já notificada suprime novo e-mail. Default 30.
# CONFORMITY_NOTIFY_DEDUPE_MINUTES=30

# -----------------------------------------------------------------------------
# Evolution GO (notificações WhatsApp — #304; provisionamento em aerobi-ansible #137)
# -----------------------------------------------------------------------------
# Aerobi → Evolution GO: a cada movimento criado (single/manual) ou lote (resumo
# agregado por grupo), o MovementNotificationsListener resolve os coordenadores do
# grupo do aeródromo e envia WhatsApp (POST /send/text, header `apikey`).
# Contrato confirmado no spike aerobi-ansible#138 (docs/EVOLUTION_GO.md).
# Consumo interno (nunca pela internet); ver src/modules/notifications/README.md.
# Base: dev no compose -> http://aerobi-evolution-go:4000 (já injetado); Nest no host
# -> http://localhost:4000 (aerobi-local-infra); prod -> http://evolution_go:4000 (warpgate).
EVOLUTION_GO_BASE_URL=http://localhost:4000
# Token DA INSTÂNCIA (não a GLOBAL_API_KEY) — gerado ao linkar a instância no manager
# (http://localhost:4000/manager). Ver aerobi-local-infra/README.md.
EVOLUTION_GO_API_KEY=
# Nome do header de auth (default `apikey`).
# EVOLUTION_GO_AUTH_HEADER=apikey
# EVOLUTION_GO_HTTP_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# Streams (câmeras + proxy HLS — épica #317)
# -----------------------------------------------------------------------------
# Listagem de câmeras por aeródromo e proxy HLS (passthrough de bytes, sem
# transcoding) do mediamtx do Raspi via tailnet. Cadastro Firestore-first
# (collection `cameras`, gerido pelo frontend) — sem tabela no Postgres. As
# rotas usam a mesma X-API-Key = AEROBI_API_KEY. Ver src/modules/streams/README.md.
#
# TTL (ms) do cache em memória da config da câmera (não consulta o Firestore a
# cada segmento HLS). Default 60000.
# STREAMS_CAMERA_CACHE_TTL_MS=60000
# Timeout (ms) do GET ao mediamtx. Default 10000.
# STREAMS_PROXY_TIMEOUT_MS=10000
# Porta do servidor HLS do mediamtx no Raspi. Default 8888.
# STREAMS_MEDIAMTX_HLS_PORT=8888

# -----------------------------------------------------------------------------
# Camera Streams (proxy HLS v2 — #473, epic #353)
# -----------------------------------------------------------------------------
# Sucessor do `Streams` acima: mesmas rotas de listagem/proxy, mas lê os
# metadados de câmera do Postgres (módulo `cameras`), não do Firestore. Roda em
# paralelo ao legado (prefixos /camera-streams e /aerodromes/:icao/camera-streams).
# Ver src/modules/camera-streams/README.md.
#
# TTL (ms) do cache em memória da resolução da câmera (não consulta o Postgres a
# cada segmento HLS). Default 60000.
# CAMERA_STREAMS_CACHE_TTL_MS=60000
# Timeout (ms) do GET ao mediamtx. Default 10000.
# CAMERA_STREAMS_PROXY_TIMEOUT_MS=10000
# Porta do servidor HLS do mediamtx no Raspi. Default 8888.
# CAMERA_STREAMS_MEDIAMTX_HLS_PORT=8888

# -----------------------------------------------------------------------------
# JWT (módulo auth — RS256)
# -----------------------------------------------------------------------------
# Par RSA assimétrico. Geração local:
#   openssl genrsa -out jwt-private.pem 4096
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#   # Codificar em base64 (linha única) para colar nas envs:
#   base64 -w0 jwt-private.pem
#   base64 -w0 jwt-public.pem
JWT_SECRET_PUBLIC_KEY=
JWT_SECRET_PRIVATE_KEY=

# TTL do access token (formato `ms` — ex: 15m, 1h, 30s).
JWT_ACCESS_TTL=15m

# TTL do refresh token (ex: 7d, 30d).
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------------------------
# Autenticação interna (users + convite + reset de senha)
# -----------------------------------------------------------------------------
# URL pública do frontend — usada para montar links de convite/reset enviados
# por email (ex: ${FRONTEND_URL}/accept-invite?token=...).
FRONTEND_URL=http://localhost:3000

# TTL do token de convite (horas).
INVITE_TTL_HOURS=72

# TTL do token de redefinição de senha (horas).
PASSWORD_RESET_TTL_HOURS=2

# -----------------------------------------------------------------------------
# Seeds (orquestrador em scripts/seeds — `npm run seed`, `seed:admin`, `seed:states`)
# -----------------------------------------------------------------------------
# `RUN_SEEDS_ON_BOOT` controla se o seed roda automaticamente após
# `prisma migrate deploy` no boot:
#   - Dev (start-dev.sh):  default **true**  — seed roda sempre que houver as
#     envs abaixo configuradas. Setar `=false` para desligar.
#   - Prod (start-prod.sh): default **false** — operator dispara manualmente
#     (`node dist/scripts/run-seeds.js`). Setar `=true` para boot automático.
# Idempotente e create-only — pode ficar ligado sem resetar senha/role de quem
# já existe (ver issue #227); cada runner faz skip silencioso sem suas envs.
# RUN_SEEDS_ON_BOOT=true

# Runner `admin` — conta ADMIN global (sem grupo). Sem signup público, é o
# caminho para destravar o sistema. Sem SEED_ADMIN_EMAIL o runner é skip.
SEED_ADMIN_EMAIL=admin@aerobi.com.br
SEED_ADMIN_PASSWORD=AdmTrocar123!
SEED_ADMIN_NAME=Admin

# Runner `states` — para cada UF cria o grupo `Grupo <Estado>`, sobe a bandeira
# do estado como imagem do grupo e cria N usuários por função. Sem
# SEED_DEFAULT_PASSWORD o runner é skip.
#
# Senha padrão de todos os usuários não-admin (>= 8 chars).
SEED_DEFAULT_PASSWORD=TrocarSenha123!
# Domínio dos emails gerados (opcional; default aerobi.com.br). Emails seguem
# `coordinator_<uf>@`, `operator_<uf>@`, `technical_<uf>@` (o 1º da função sem
# sufixo, do 2º em diante com `_n`).
# SEED_EMAIL_DOMAIN=aerobi.com.br
# Quantos usuários de cada função criar por estado (inteiro >= 0; default 1).
# SEED_COORDINATORS_PER_STATE=1
# SEED_OPERATORS_PER_STATE=1
# SEED_TECHNICALS_PER_STATE=1

# -----------------------------------------------------------------------------
# Email (EmailService / @nestjs-modules/mailer)
# -----------------------------------------------------------------------------
# Em NODE_ENV=development o EmailService usa Ethereal (https://ethereal.email):
#   - Se ETHEREAL_USERNAME / ETHEREAL_PASSWORD estiverem definidos, usa essa conta;
#   - Caso contrário, cria uma conta temporária automaticamente (expira em 48h).
# Em produção, use SMTP real — MAIL_HOST/MAIL_USER/MAIL_PASS são obrigatórios.
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
MAIL_USER_NO_REPLY=noreply@aerobi.local

# Development only (opcional — sem isto usa createTestAccount automático)
ETHEREAL_USERNAME=
ETHEREAL_PASSWORD=

# -----------------------------------------------------------------------------
# Referência — produção (docker-compose.prod.yml + rede Docker warpgate)
# -----------------------------------------------------------------------------
# A rede **warpgate** é a bridge partilhada com Postgres e outras apps (Ansible),
# não o binário Warpgate (`docker network create warpgate`).
#
# No servidor (.env ou secrets do deploy), além das variáveis acima:
#
#   NODE_ENV=production
#   PORT=3333
#   DATABASE_URL=postgresql://USER:PASS@postgres:5432/DB_AEROBI?schema=public
#     (host `postgres` = container PostgreSQL na rede warpgate)
#   CORS_ORIGINS=https://teu-dominio.com
#
# Build / imagem (exemplos):
#   REGISTRY=ghcr.io
#   IMAGE_NAME=<owner>/<repo>
#   TAG=<versão semântica>
#
# GitHub Actions (deploy.yml) — secrets típicos:
#   SSH_PRIVATE_KEY, REMOTE_HOST, REMOTE_PORT, REMOTE_USER, REMOTE_TARGET,
#   GH_TOKEN (read:packages + release: repo),
#   DATABASE_URL, CORS_ORIGINS, APP_PORT (opcional; default 3333),
#   ANAC_RAB_INDEX_URL, HTTP_USER_AGENT,
#   AEROBI_API_KEY (substitui o antigo RAB_SYNC_API_KEY; não usar mais esse nome no GitHub),
#   AEROBI_REQUIRE_AUTH (opcional),
#   PLUGFIELD_API_KEY, PLUGFIELD_TOKEN (proxy Plugfield no servidor),
#   PLUGFIELD_API_BASE_URL, PLUGFIELD_HTTP_TIMEOUT_MS (opcionais),
#   EVOLUTION_GO_BASE_URL, EVOLUTION_GO_API_KEY (token da instância; notificações WhatsApp),
#   EVOLUTION_GO_AUTH_HEADER, EVOLUTION_GO_HTTP_TIMEOUT_MS (opcionais),
#   RAB_SYNC_CRON, RAB_SYNC_CRON_DISABLED (opcional; só agendamento, não auth)
